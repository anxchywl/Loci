# ── app ─────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# ── telegram ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_MINI_APP_URL=
# reject initData older than this; keep <=300 in production
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=300

# ── location privacy ────────────────────────────────────────────────
# keys the deterministic fuzz offset; leaking it makes approx locations reversible
LOCATION_FUZZ_SECRET=change-me-fuzz

# ── auth ────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
AUTH_REQUESTS_PER_MINUTE=10
STORY_CREATE_PER_DAY=10

# ── postgres (postgis) ──────────────────────────────────────────────
POSTGRES_DB=loci
POSTGRES_USER=loci
POSTGRES_PASSWORD=loci
# host port for local tooling; container port is always 5432
POSTGRES_PORT=5433
# set when moving postgresql to a managed service
DATABASE_URL=

# connection pool limits apply per api process
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=3
DB_POOL_TIMEOUT_SECONDS=10
# query timeout protects the connection pool
DB_STATEMENT_TIMEOUT_MS=30000

# ── redis ───────────────────────────────────────────────────────────
REDIS_PASSWORD=loci-redis
REDIS_DB=0
# set these when moving redis or celery to managed services
REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ── object storage (minio in dev, cloudflare r2 in prod) ───────────
S3_ENDPOINT=minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=loci
S3_SECRET_KEY=loci-password
S3_SECURE=false
S3_MEDIA_BUCKET=loci-media
S3_PRESIGNED_URL_EXPIRES_SECONDS=600
# browser origins allowed to upload directly to the bucket via presigned URLs.
# json list; leave empty to reuse ALLOWED_ORIGINS. required for the fast
# direct-upload path to work in the browser (otherwise it falls back to proxy).
S3_CORS_ALLOWED_ORIGINS=[]

# ── observability ───────────────────────────────────────────────────
# bearer token guarding GET /metrics (prometheus text). empty = no auth.
METRICS_TOKEN=
# required only when the production monitoring profile is enabled
GRAFANA_ADMIN_PASSWORD=
MONITORING_ENABLED=true
GRAFANA_PORT=3001

# ── frontend ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
# low zoom levels use server aggregated clusters
NEXT_PUBLIC_SERVER_CLUSTER_MAX_ZOOM=9

# ── cors ────────────────────────────────────────────────────────────
# json list, e.g. ["https://app.example.com"]
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── production only ─────────────────────────────────────────────────
CADDY_DOMAIN=
REGISTRY_OWNER=
# dedicated or shared-host
DEPLOYMENT_TARGET=dedicated
# comma- or space-separated telegram ids granted the moderation queue
ADMIN_TELEGRAM_IDS=
# set false to disable telegram status-change notifications (e.g. in tests)
NOTIFICATIONS_ENABLED=true
WEB_CONCURRENCY=3
BACKUP_RETENTION_DAYS=14
BACKUP_MAX_AGE_HOURS=26
BACKUP_DIR=/opt/loci/backups
# dedicated private r2 bucket and scoped credentials for database backups
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=loci-db-backups
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
# keep the private age identity offline
BACKUP_AGE_RECIPIENT=
