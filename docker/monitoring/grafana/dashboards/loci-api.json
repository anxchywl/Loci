{
  "annotations": {"list": []},
  "editable": false,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "targets": [{"expr": "sum by (route) (rate(http_requests_total[5m]))", "legendFormat": "{{route}}"}],
      "title": "Request rate by route",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, route) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "{{route}}"}],
      "title": "HTTP p95 latency by route",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit"}},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8},
      "id": 3,
      "targets": [{"expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 0.001)", "legendFormat": "5xx"}],
      "title": "HTTP error ratio",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit"}},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8},
      "id": 4,
      "targets": [{"expr": "db_pool_connections_checked_out / clamp_min(db_pool_connection_capacity, 1)", "legendFormat": "pool"}],
      "title": "Database pool utilization",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8},
      "id": 5,
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, operation) (rate(db_query_duration_seconds_bucket[5m])))", "legendFormat": "db {{operation}}"},
        {"expr": "histogram_quantile(0.95, sum by (le, command) (rate(redis_command_duration_seconds_bucket[5m])))", "legendFormat": "redis {{command}}"}
      ],
      "title": "Database and Redis p95 latency",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 16},
      "id": 6,
      "targets": [{"expr": "celery_queue_depth", "legendFormat": "{{queue}}"}],
      "title": "Celery queue depth",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 16},
      "id": 7,
      "targets": [{"expr": "loci_backup_age_seconds", "legendFormat": "latest"}],
      "title": "Backup age",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit"}},
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 16},
      "id": 8,
      "targets": [{"expr": "1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes", "legendFormat": "host"}],
      "title": "Host memory utilization",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percentunit"}},
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 16},
      "id": 9,
      "targets": [{"expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\"loci-.*\"}[5m]))", "legendFormat": "{{name}}"}],
      "title": "Container CPU",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 41,
  "tags": ["loci", "api"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "title": "Loci API",
  "uid": "loci-api"
}
